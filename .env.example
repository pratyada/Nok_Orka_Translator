# OpenAI - Primary translation engine
OPENAI_API_KEY=sk-...

# Anthropic - Fallback translation (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram - Fallback STT
DEEPGRAM_API_KEY=...

# Server
PORT=3001
NODE_ENV=development

# Redis (session state)
REDIS_URL=redis://localhost:6379

# PostgreSQL (transcript storage)
DATABASE_URL=postgresql://orka:orka@localhost:5432/orka_transcripts

# Azure Entra ID (Teams SSO)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
