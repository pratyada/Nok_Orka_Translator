{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "0.1.0",
  "id": "{{BOT_ID}}",
  "developer": {
    "name": "Nokia",
    "websiteUrl": "https://nokia.com",
    "privacyUrl": "https://nokia.com/privacy",
    "termsOfUseUrl": "https://nokia.com/terms"
  },
  "name": {
    "short": "Orka Translator",
    "full": "Nokia Orka Live Meeting Translator"
  },
  "description": {
    "short": "Real-time speech translation for Teams meetings",
    "full": "Nokia Orka Translator provides real-time translation during Teams meetings. The bot joins your meeting, captures live transcripts, and delivers translations in your preferred language. Supports English, Spanish, French, and Portuguese."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#124191",
  "bots": [
    {
      "botId": "{{BOT_ID}}",
      "scopes": ["personal", "team", "groupchat"],
      "commandLists": [
        {
          "scopes": ["personal", "groupchat"],
          "commands": [
            {
              "title": "translate to spanish",
              "description": "Set target language to Spanish"
            },
            {
              "title": "translate to french",
              "description": "Set target language to French"
            },
            {
              "title": "translate to portuguese",
              "description": "Set target language to Portuguese"
            },
            {
              "title": "stop",
              "description": "Stop translation"
            },
            {
              "title": "status",
              "description": "Show current translation status"
            }
          ]
        }
      ],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "{{BASE_URL}}/config",
      "canUpdateConfiguration": true,
      "scopes": ["groupchat"],
      "context": ["meetingSidePanel"],
      "meetingSurfaces": {
        "sidePanel": {
          "preferredWidth": 400
        }
      }
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["{{BOT_HOSTNAME}}"],
  "webApplicationInfo": {
    "id": "{{BOT_ID}}",
    "resource": "api://{{BOT_HOSTNAME}}/{{BOT_ID}}"
  }
}
