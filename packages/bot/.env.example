# Bot Framework
BOT_ID=                      # Azure Bot registration App ID
BOT_PASSWORD=                # Azure Bot registration password
BOT_HOSTNAME=localhost:3978  # Public hostname (use ngrok for dev)

# Azure Entra ID
AZURE_TENANT_ID=             # Nokia's Azure tenant ID
AZURE_CLIENT_ID=             # Same as BOT_ID for single-tenant
AZURE_CLIENT_SECRET=         # Client secret for Graph API access

# OpenAI
OPENAI_API_KEY=              # Same key as main server

# Server
BOT_PORT=3978
