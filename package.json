{
  "name": "nokia-orka-translator",
  "version": "1.0.1",
  "private": true,
  "description": "Nokia Orka Translator - In-house live translation for Teams meetings",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/app",
    "packages/desktop",
    "packages/bot"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:server": "npm run dev -w packages/server",
    "dev:app": "npm run dev -w packages/app",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "test:pipeline": "npx tsx scripts/test-pipeline.ts",
    "dev:desktop": "npm run dev -w packages/desktop",
    "build:desktop": "npm run build -w packages/desktop",
    "package:desktop": "npm run package -w packages/desktop"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
